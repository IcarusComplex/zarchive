<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Needed to launch Android's package installer on the downloaded update APK (Phase 12). -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- Runtime-requested (API 33+) the first time the user enables Search Monitors, required
         for MonitorWorker's local notifications to actually show. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Requested (via Settings.ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS) the first time the
         user enables Search Monitors. WorkManager's periodic job is otherwise a prime target for
         OEM battery managers (Samsung's "Sleeping apps" in particular) to kill outright while the
         app is fully closed for hours; confirmed on a real device, zero periodic runs over a
         5+ hour closed window, resuming instantly on relaunch. This is standard practice for a
         sideloaded background-scheduling app (not distributed via Play Store, so Play's abuse
         policy around this permission doesn't apply). -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- MonitorForegroundService: the battery-optimization exemption above turned out not to be
         enough by itself (confirmed on a real device: still zero checks over a closed-app window
         with the exemption granted, and no further per-app toggle available to try). A foreground
         service with a persistent notification is the stronger, OEM-agnostic fallback. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Restarts MonitorForegroundService after a reboot; the service itself does not survive one. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name="androidapp.ZArchiveApplication"
        android:label="${appLabel}"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:enableOnBackInvokedCallback="true"
        android:networkSecurityConfig="@xml/network_security_config">
        <!-- configChanges: SearchViewModel lives in a plain Compose `remember` tied to this
             Activity (Phase 13 finding), not a retained-across-recreation ViewModel. Without this,
             Android's default rotation/multi-window-resize behavior destroys and recreates the
             Activity, silently wiping in-progress search state. Handling the change ourselves keeps
             the same Activity instance alive; Compose recomposes for the new size/orientation for
             free. -->
        <activity
            android:name="androidapp.MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboardHidden|uiMode"
            android:theme="@style/Theme.ZArchive.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Exposes the downloaded update APK (in cacheDir) to Android's package installer via a
             content:// URI. Installers on API 24+ cannot be handed a raw file:// URI. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <service
            android:name="monitor.MonitorForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <receiver
            android:name="monitor.MonitorBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
