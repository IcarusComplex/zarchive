# ── Build output ──────────────────────────────────────────────
# Compose/jpackage app image, compiled classes, the bundled JRE,
# Playwright's driver-bundle, Skiko natives — all regenerated by Gradle.
/build/
build/

# Packaged distributables (the shareable .zip + app image)
/dist/

# ── Gradle ────────────────────────────────────────────────────
.gradle/
gradle-app.setting
!gradle/wrapper/gradle-wrapper.jar   # wrapper jar IS tracked (needed to build)

# ── Recovery / backup folders (kept on disk, not in git) ──────
/RECOVERY/

# ── Compiled / generated bytecode ─────────────────────────────
*.class

# ── IDE / editor ──────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.vscode/

# ── OS cruft ──────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Claude Code machine-local settings ────────────────────────
.claude/settings.local.json

# ── Secrets (never commit) ────────────────────────────────────
secrets.properties
